{
  "name": "@wezon/wz-grid-core",
  "version": "0.1.0",
  "description": "Framework-agnostic headless core for WZ-Grid — pure TypeScript engines and types.",
  "keywords": [
    "grid",
    "datagrid",
    "table",
    "virtual-scroll",
    "typescript",
    "headless",
    "sort",
    "filter",
    "tree",
    "grouping",
    "merge",
    "undo-redo",
    "csv",
    "excel"
  ],
  "license": "MIT",
  "author": "(주)위존",
  "homepage": "https://github.com/cheerjo/wz-grid#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/cheerjo/wz-grid.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/cheerjo/wz-grid/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/wz-grid-core.cjs.js",
  "module": "dist/wz-grid-core.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/wz-grid-core.es.js",
      "require": "./dist/wz-grid-core.cjs.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "scripts": {
    "build": "vite build --config vite.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "exceljs": ">=4.3.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.5.4"
  }
}
