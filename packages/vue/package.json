{
  "name": "wz-grid-vue",
  "version": "1.5.0",
  "description": "Vue 2/3 component for WZ-Grid — 엔터프라이즈급 그리드 컴포넌트",
  "keywords": [
    "vue",
    "vue2",
    "vue3",
    "grid",
    "datagrid",
    "table",
    "virtual-scroll",
    "typescript",
    "tree",
    "grouping",
    "cell-merge",
    "undo-redo",
    "excel",
    "csv",
    "enterprise"
  ],
  "license": "MIT",
  "author": "(주)위존",
  "homepage": "https://github.com/cheerjo/wz-grid#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/cheerjo/wz-grid.git",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/cheerjo/wz-grid/issues"
  },
  "type": "module",
  "main": "dist/wz-grid-vue.cjs.js",
  "module": "dist/wz-grid-vue.es.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/wz-grid-vue.es.js",
      "require": "./dist/wz-grid-vue.cjs.js"
    },
    "./dist/wz-grid-vue.css": "./dist/wz-grid-vue.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "scripts": {
    "build": "vite build --config vite.lib.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@wezon/wz-grid-core": "workspace:*",
    "vue-demi": "^0.14.6"
  },
  "peerDependencies": {
    "@vue/composition-api": "^1.0.0-rc.1",
    "vue": "^2.7.0 || >=3.0.0"
  },
  "peerDependenciesMeta": {
    "@vue/composition-api": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.0.0",
    "autoprefixer": "^10.4.14",
    "postcss": "^8.4.24",
    "tailwindcss": "^3.3.2",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.3.0"
  }
}
