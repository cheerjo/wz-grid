{
  "name": "wz-grid",
  "version": "1.5.0",
  "private": true,
  "description": "Vue 2/3 Universal High-Quality Grid Component (workspace root)",
  "keywords": [
    "vue",
    "grid",
    "datagrid",
    "table",
    "vue3",
    "vue2",
    "virtual-scroll"
  ],
  "license": "MIT",
  "author": "cheerjo",
  "repository": {
    "type": "git",
    "url": "https://github.com/cheerjo/wz-grid.git"
  },
  "homepage": "https://cheerjo.github.io/wz-grid/",
  "bugs": {
    "url": "https://github.com/cheerjo/wz-grid/issues"
  },
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "pnpm --filter @wezon/wz-grid-vue build",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "build:core": "pnpm --filter @wezon/wz-grid-core build",
    "build:vue-pkg": "pnpm --filter @wezon/wz-grid-vue build",
    "build:packages": "pnpm --filter @wezon/wz-grid-core build && pnpm --filter @wezon/wz-grid-vue build"
  },
  "dependencies": {
    "exceljs": ">=4.3.0",
    "vue-demi": "^0.14.6"
  },
  "peerDependencies": {
    "@vue/composition-api": "^1.0.0-rc.1",
    "vue": "^2.7.0 || >=3.0.0"
  },
  "peerDependenciesMeta": {
    "@vue/composition-api": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.14",
    "jsdom": "^25.0.1",
    "msw": "^2.12.10",
    "postcss": "^8.4.24",
    "tailwindcss": "^3.3.2",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^1.6.4",
    "vitest": "^2.1.9",
    "vue": "^3.3.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
