{
  "name": "wz-grid-vue",
  "version": "1.5.0",
  "description": "WZ-Grid Vue 2/3 wrapper",
  "license": "MIT",
  "type": "module",
  "main": "dist/wz-grid-vue.cjs.js",
  "module": "dist/wz-grid-vue.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/wz-grid-vue.es.js",
      "require": "./dist/wz-grid-vue.cjs.js"
    },
    "./dist/wz-grid-vue.css": "./dist/wz-grid-vue.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build --config vite.lib.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic/wz-grid-core": "workspace:*",
    "vue-demi": "^0.14.6"
  },
  "peerDependencies": {
    "@vue/composition-api": "^1.0.0-rc.1",
    "vue": "^2.7.0 || >=3.0.0"
  },
  "peerDependenciesMeta": {
    "@vue/composition-api": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.0.0",
    "autoprefixer": "^10.4.14",
    "postcss": "^8.4.24",
    "tailwindcss": "^3.3.2",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.3.0"
  }
}
