{
  "name": "wz-grid",
  "version": "1.3.1",
  "description": "Vue 2/3 Universal High-Quality Grid Component",
  "keywords": [
    "vue",
    "grid",
    "datagrid",
    "table",
    "vue3",
    "vue2",
    "virtual-scroll"
  ],
  "license": "SEE LICENSE IN LICENSE.md",
  "author": "cheerjo",
  "repository": {
    "type": "git",
    "url": "https://github.com/cheerjo/wz-grid.git"
  },
  "homepage": "https://cheerjo.github.io/wz-grid/",
  "bugs": {
    "url": "https://github.com/cheerjo/wz-grid/issues"
  },
  "main": "dist/wz-grid.cjs.js",
  "module": "dist/wz-grid.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/wz-grid.es.js",
      "require": "./dist/wz-grid.cjs.js"
    },
    "./dist/wz-grid.css": "./dist/wz-grid.css"
  },
  "files": [
    "dist/wz-grid.es.js",
    "dist/wz-grid.cjs.js",
    "dist/wz-grid.css",
    "dist/index.d.ts",
    "dist/components",
    "dist/composables",
    "dist/types",
    "dist/utils",
    "LICENSE.md",
    "README.md"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "vue-demi": "^0.14.6"
  },
  "peerDependencies": {
    "@vue/composition-api": "^1.0.0-rc.1",
    "vue": "^2.7.0 || >=3.0.0",
    "xlsx": ">=0.18.0"
  },
  "peerDependenciesMeta": {
    "@vue/composition-api": {
      "optional": true
    },
    "xlsx": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.0.0",
    "autoprefixer": "^10.4.14",
    "msw": "^2.12.10",
    "postcss": "^8.4.24",
    "tailwindcss": "^3.3.2",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^1.6.4",
    "vue": "^3.3.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}