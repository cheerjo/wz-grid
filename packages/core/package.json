{
  "name": "@wezon/wz-grid-core",
  "version": "0.1.0",
  "description": "WZ-Grid headless core — pure TypeScript, no framework dependency",
  "license": "MIT",
  "type": "module",
  "main": "dist/wz-grid-core.cjs.js",
  "module": "dist/wz-grid-core.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/wz-grid-core.es.js",
      "require": "./dist/wz-grid-core.cjs.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build --config vite.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "exceljs": ">=4.3.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.5.4"
  }
}
