{
  "name": "@wezon/wz-grid-react",
  "version": "0.2.0",
  "description": "React wrapper for WZ-Grid — built on @wezon/wz-grid-core",
  "keywords": [
    "react",
    "grid",
    "datagrid",
    "table",
    "virtual-scroll",
    "typescript",
    "sort",
    "filter",
    "pagination",
    "checkbox",
    "undo-redo",
    "headless"
  ],
  "license": "MIT",
  "author": "(주)위존",
  "homepage": "https://github.com/cheerjo/wz-grid#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/cheerjo/wz-grid.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/cheerjo/wz-grid/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/wz-grid-react.cjs.js",
  "module": "dist/wz-grid-react.es.js",
  "types": "dist/react/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/react/src/index.d.ts",
      "import": "./dist/wz-grid-react.es.js",
      "require": "./dist/wz-grid-react.cjs.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "scripts": {
    "build": "vite build --config vite.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@wezon/wz-grid-core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.0.0"
  }
}
